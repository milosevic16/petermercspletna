# Copy to .env.local (gitignored) and fill in for local development.
# In production, set this in Netlify → Site settings → Environment variables.
#
# Web3Forms access key for the contact form. Public-by-design (it ships in the
# client bundle so the browser can POST to Web3Forms) — get one at web3forms.com.
VITE_WEB3FORMS_KEY=
